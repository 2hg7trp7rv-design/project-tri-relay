{
  "name": "tri-relay-last-shift",
  "version": "0.4.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "install:ci": "bash scripts/install-ci.sh",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vite",
    "dev:vercel": "next dev",
    "build": "node scripts/build-target.mjs",
    "build:sites": "bash scripts/build-verified.sh",
    "build:vercel": "next build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "start:vercel": "next start",
    "test": "npm run build:sites && node --test tests/rendered-html.test.mjs tests/media-assets.test.mjs tests/deployment-config.test.mjs tests/http-policy.test.mjs && node --experimental-strip-types --test tests/engine.test.ts tests/audio.test.ts tests/persistence.test.ts tests/platform.test.ts tests/debrief.test.ts tests/playtest-metrics.test.ts",
    "verify:vercel": "npm run build:vercel",
    "simulate": "node --experimental-strip-types scripts/simulate.mts",
    "validate:artifact": "bash scripts/validate-artifact.sh",
    "check:release": "node scripts/check-release-readiness.mjs",
    "check:commercial": "node scripts/check-release-readiness.mjs --commercial",
    "lint": "bash scripts/sites-env.sh -- eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern .sites-runtime",
    "db:generate": "bash scripts/sites-env.sh -- drizzle-kit generate"
  },
  "dependencies": {
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module",
  "displayName": "TRI RELAY LAST SHIFT"
}
